---
import type { Post } from '../lib/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const dateLabel = post.timestamp.toISOString().slice(0, 10);
---

<section class="post-detail" data-detail-id={post.id}>
  <header class="post-detail__header">
    <span class="post-detail__type">{post.type}</span>
    <h2 class="post-detail__title">{post.title}</h2>
    <p class="post-detail__meta">
      <a class="post-detail__author" href={post.authorUrl ?? '#'}>{post.author}</a>
      <time datetime={post.timestamp.toISOString()}>{dateLabel}</time>
      {post.updated && <span>(updated {post.updated.toISOString().slice(0, 10)})</span>}
    </p>
    <p class="post-detail__links">
      {post.resource && <a href={post.resource} target="_blank" rel="noopener">元サイト ↗</a>}
      {post.fileUrl && <a href={post.fileUrl} target="_blank" rel="noopener">ソース ↗</a>}
    </p>
  </header>
  <div class="post-detail__body">
    <slot />
  </div>
  {post.tags.length > 0 && (
    <ul class="post-detail__tags">
      {post.tags.map((tag) => <li class="post-detail__tag">#{tag}</li>)}
    </ul>
  )}
</section>
